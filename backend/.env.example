# Shared
AUTH_JWT_SECRET=change-me

# Gateway
GATEWAY_HTTP_LISTEN_ADDR=:8080
AUTH_SERVICE_GRPC_ADDR=auth:50051
RECOMMENDATION_SERVICE_GRPC_ADDR=recommendation:50064
GATEWAY_REFRESH_COOKIE_NAME=jc_refresh_token
GATEWAY_REFRESH_COOKIE_DOMAIN=
GATEWAY_REFRESH_COOKIE_SECURE=false
GATEWAY_REFRESH_COOKIE_HTTP_ONLY=true
GATEWAY_REFRESH_COOKIE_PATH=/
GATEWAY_REFRESH_COOKIE_SAME_SITE=lax
GATEWAY_OAUTH_STATE_SECRET=change-me
GATEWAY_OAUTH_GOOGLE_CLIENT_ID=
GATEWAY_OAUTH_GOOGLE_CLIENT_SECRET=
GATEWAY_OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/google/callback
GATEWAY_OAUTH_GITHUB_CLIENT_ID=
GATEWAY_OAUTH_GITHUB_CLIENT_SECRET=
GATEWAY_OAUTH_GITHUB_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth/github/callback

# Auth service
AUTH_GRPC_LISTEN_ADDR=:50051
AUTH_POSTGRES_URL=postgres://auth:auth@postgres:5432/jobconnect_auth?sslmode=disable
AUTH_ACCESS_TOKEN_TTL_SECONDS=9000
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_OTP_TTL_SECONDS=900
USER_SERVICE_GRPC_ADDR=user:50052

# User service
USER_GRPC_LISTEN_ADDR=:50052
USER_POSTGRES_URL=postgres://user:user@postgres:5432/jobconnect_user?sslmode=disable
USER_AVATAR_STORAGE_PROVIDER=minio
USER_AVATAR_STORAGE_BUCKET=jobconnect-avatars
USER_AVATAR_STORAGE_ENDPOINT=minio:9000
USER_AVATAR_STORAGE_REGION=us-east-1
USER_AVATAR_STORAGE_ACCESS_KEY=minioadmin
USER_AVATAR_STORAGE_SECRET_KEY=minioadmin
USER_AVATAR_STORAGE_USE_SSL=false
USER_AVATAR_STORAGE_PATH_STYLE=true
USER_AVATAR_STORAGE_CREATE_BUCKET=true
USER_PORTFOLIO_STORAGE_PROVIDER=minio
USER_PORTFOLIO_STORAGE_BUCKET=jobconnect-portfolio-media
USER_PORTFOLIO_STORAGE_ENDPOINT=minio:9000
USER_PORTFOLIO_STORAGE_REGION=us-east-1
USER_PORTFOLIO_STORAGE_ACCESS_KEY=minioadmin
USER_PORTFOLIO_STORAGE_SECRET_KEY=minioadmin
USER_PORTFOLIO_STORAGE_USE_SSL=false
USER_PORTFOLIO_STORAGE_PATH_STYLE=true
USER_PORTFOLIO_STORAGE_CREATE_BUCKET=true
USER_CV_STORAGE_PROVIDER=minio
USER_CV_STORAGE_BUCKET=jobconnect-cvs
USER_CV_STORAGE_ENDPOINT=minio:9000
USER_CV_STORAGE_REGION=us-east-1
USER_CV_STORAGE_ACCESS_KEY=minioadmin
USER_CV_STORAGE_SECRET_KEY=minioadmin
USER_CV_STORAGE_USE_SSL=false
USER_CV_STORAGE_PATH_STYLE=true
USER_CV_STORAGE_CREATE_BUCKET=true

# Job service
JOB_GRPC_LISTEN_ADDR=:50053
JOB_POSTGRES_URL=postgres://job:job@postgres:5432/jobconnect_job?sslmode=disable
JOB_ATTACHMENT_STORAGE_PROVIDER=minio
JOB_ATTACHMENT_STORAGE_BUCKET=jobconnect-job-attachments
JOB_ATTACHMENT_STORAGE_ENDPOINT=minio:9000
JOB_ATTACHMENT_STORAGE_REGION=us-east-1
JOB_ATTACHMENT_STORAGE_ACCESS_KEY=minioadmin
JOB_ATTACHMENT_STORAGE_SECRET_KEY=minioadmin
JOB_ATTACHMENT_STORAGE_USE_SSL=false
JOB_ATTACHMENT_STORAGE_PATH_STYLE=true
JOB_ATTACHMENT_STORAGE_CREATE_BUCKET=true

# Proposal service
PROPOSAL_GRPC_LISTEN_ADDR=:50054
PROPOSAL_POSTGRES_URL=postgres://proposal:proposal@postgres:5432/jobconnect_proposal?sslmode=disable
JOB_SERVICE_GRPC_ADDR=job:50053

# Contract service
CONTRACT_GRPC_LISTEN_ADDR=:50055
CONTRACT_POSTGRES_URL=postgres://contract:contract@postgres:5432/jobconnect_contract?sslmode=disable
PROPOSAL_SERVICE_GRPC_ADDR=proposal:50054

# Wallet service
WALLET_GRPC_LISTEN_ADDR=:50059
WALLET_POSTGRES_URL=postgres://wallet:wallet@postgres:5432/jobconnect_wallet?sslmode=disable

# Review service
REVIEW_GRPC_LISTEN_ADDR=:50056
REVIEW_POSTGRES_URL=postgres://review:review@postgres:5432/jobconnect_review?sslmode=disable

# Recommendation service
RECOMMENDATION_GRPC_LISTEN_ADDR=:50064
JOB_SERVICE_ADDR=job:50053
USER_SERVICE_ADDR=user:50052
REVIEW_SERVICE_ADDR=review:50056
RECOMMENDATION_CACHE_BACKEND=redis
RECOMMENDATION_REDIS_ADDR=redis:6379
RECOMMENDATION_REDIS_PASSWORD=
RECOMMENDATION_REDIS_DB=0
RECOMMENDATION_DEFAULT_LIMIT=10
RECOMMENDATION_MAX_LIMIT=25
RECOMMENDATION_CANDIDATE_PAGE_SIZE=100
RECOMMENDATION_PER_SKILL_PAGE_SIZE=25
RECOMMENDATION_MAX_SKILL_QUERIES=5
RECOMMENDATION_CACHE_TTL=2m
