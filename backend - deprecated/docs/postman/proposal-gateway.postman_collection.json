{
  "info": {
    "_postman_id": "9aa4a568-5606-42ce-8e6f-a3a9d7cb0f35",
    "name": "JobConnect Proposal Service (Gateway HTTP)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Gateway HTTP requests for Proposal service operations currently exposed at /api/v1/proposals. Includes auth bootstrap requests to obtain client and freelancer bearer tokens."
  },
  "item": [
    {
      "name": "Auth Bootstrap",
      "item": [
        {
          "name": "Login Client",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{clientEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Gets client access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.environment.set('clientToken', json.access_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Freelancer",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{freelancerEmail}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            },
            "description": "Gets freelancer access token."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access_token) {",
                  "  pm.environment.set('freelancerToken', json.access_token);",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Proposal (Freelancer)",
      "item": [
        {
          "name": "Get My Proposal For Job",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{freelancerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/proposals/me/jobs/{{jobId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "proposals",
                "me",
                "jobs",
                "{{jobId}}"
              ]
            }
          }
        },
        {
          "name": "Has Applied To Job",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{freelancerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/proposals/me/jobs/{{jobId}}/has-applied",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "proposals",
                "me",
                "jobs",
                "{{jobId}}",
                "has-applied"
              ]
            }
          }
        },
        {
          "name": "List My Proposals",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{freelancerToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/proposals/me?page_size=20&sort_by=newest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "proposals",
                "me"
              ],
              "query": [
                {
                  "key": "page_size",
                  "value": "20"
                },
                {
                  "key": "sort_by",
                  "value": "newest"
                }
              ]
            }
          }
        },
        {
          "name": "Get Attachment Upload URL",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{freelancerToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"file_name\": \"portfolio.pdf\",\n  \"content_type\": \"application/pdf\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/proposals/{{proposalId}}/attachments/upload-url",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "proposals",
                "{{proposalId}}",
                "attachments",
                "upload-url"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Proposal (Client)",
      "item": [
        {
          "name": "Get Proposal",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/proposals/{{proposalId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "proposals",
                "{{proposalId}}"
              ]
            }
          }
        },
        {
          "name": "List Client Proposals",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/proposals/client?page_size=20&sort_by=newest",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "proposals",
                "client"
              ],
              "query": [
                {
                  "key": "page_size",
                  "value": "20"
                },
                {
                  "key": "sort_by",
                  "value": "newest"
                }
              ]
            }
          }
        },
        {
          "name": "Count Client Proposal Inbox",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/proposals/client/counts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "proposals",
                "client",
                "counts"
              ]
            }
          }
        },
        {
          "name": "Count Proposals By Job",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/proposals/jobs/{{jobId}}/counts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "proposals",
                "jobs",
                "{{jobId}}",
                "counts"
              ]
            }
          }
        },
        {
          "name": "Set Proposal Decision",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"decision\": \"shortlisted\",\n  \"reason\": \"Strong fit for the role\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/proposals/{{proposalId}}/decision",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "proposals",
                "{{proposalId}}",
                "decision"
              ]
            }
          }
        },
        {
          "name": "Get Attachment Download URL",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{clientToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/proposals/{{proposalId}}/attachments/{{attachmentId}}/download-url",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "proposals",
                "{{proposalId}}",
                "attachments",
                "{{attachmentId}}",
                "download-url"
              ]
            }
          }
        }
      ]
    }
  ]
}
